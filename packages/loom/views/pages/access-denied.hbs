{{#if embed}}
  <div class="loom-access-denied loom-access-denied--embed rounded-lg border border-default bg-neutral-primary p-6 text-center">
    <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-danger-soft text-fg-danger">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
      </svg>
    </div>
    <h2 class="text-base font-semibold text-heading">{{or pageTitle 'Access denied'}}</h2>
    <p class="mt-2 text-sm text-body-subtle">{{or message 'You do not have permission to perform this action.'}}</p>
  </div>
{{else}}
  <div class="mx-auto flex max-w-lg flex-col items-center px-4 py-16 text-center">
    <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-danger-soft text-fg-danger">
      <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.75" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"/>
      </svg>
    </div>
    <p class="text-xs font-semibold uppercase tracking-wider text-fg-danger">403</p>
    <h1 class="mt-2 text-2xl font-semibold text-heading">{{or pageTitle 'Access denied'}}</h1>
    <p class="mt-3 text-sm text-body-subtle">{{or message 'You do not have permission to perform this action.'}}</p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-2">
      {{#if resource}}
        <a href="{{basePath}}/{{resource.slug}}" class="inline-flex items-center gap-1.5 rounded-md border border-default px-3 py-1.5 text-sm font-medium text-body hover:bg-surface-hover">
          Back to {{resource.label}}
        </a>
      {{/if}}
      <a href="{{basePath}}" class="inline-flex items-center gap-1.5 rounded-md bg-fg-brand px-3 py-1.5 text-sm font-medium text-white hover:opacity-90">
        Dashboard
      </a>
    </div>
  </div>
{{/if}}
