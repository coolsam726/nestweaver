<section class="portal-welcome site-rise">
  <p class="portal-welcome__kicker">Account</p>
  <h1 class="portal-welcome__title">Change password</h1>
  <p class="portal-welcome__lede">
    Choose a new password. You’ll need to sign in again after it updates.
  </p>
</section>

{{#if flash}}
  <div
    class="portal-flash site-rise {{#if (eq flash.type 'error')}}portal-flash--error{{else}}portal-flash--success{{/if}}"
    role="status"
  >
    {{flash.message}}
  </div>
{{/if}}

<section class="portal-form-card site-rise site-rise-delay-1">
  <form method="post" action="{{profilePasswordPath}}" class="portal-form">
    {{> csrf}}
    <div class="portal-form__field">
      <label for="currentPassword" class="portal-form__label">Current password</label>
      <input
        id="currentPassword"
        type="password"
        name="currentPassword"
        required
        autofocus
        autocomplete="current-password"
        class="loom-input"
      />
    </div>
    <div class="portal-form__field">
      <label for="password" class="portal-form__label">New password</label>
      <input
        id="password"
        type="password"
        name="password"
        required
        minlength="8"
        autocomplete="new-password"
        class="loom-input"
      />
    </div>
    <div class="portal-form__field">
      <label for="passwordConfirm" class="portal-form__label">Confirm new password</label>
      <input
        id="passwordConfirm"
        type="password"
        name="passwordConfirm"
        required
        minlength="8"
        autocomplete="new-password"
        class="loom-input"
      />
    </div>
    <div class="portal-form__actions">
      <button type="submit" class="site-btn site-btn--primary">Update password</button>
      <a href="{{profilePath}}" class="site-btn site-btn--ghost">Cancel</a>
    </div>
  </form>
</section>
