{
  "name": "@nodeweaver/persistence",
  "version": "0.1.0",
  "description": "Shared ORM-agnostic persistence primitives for Nodeweaver packs (ids, model maps, store factory options). Not a fifth ORM.",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/coolsam726/nodeweaver.git",
    "directory": "packages/persistence"
  },
  "publishConfig": { "access": "public" }
}
